# FenceGuard Lite — Environment Configuration
# Copy this file to .env and fill in the values

# ── Gateway (Java Spring Boot) ──────────────────────────
FENCEGUARD_API_KEY=changeme-generate-a-strong-random-key
FENCEGUARD_HOST=127.0.0.1
FENCEGUARD_PORT=8080

# ── Internal gRPC channel ──────────────────────────────
FENCEGUARD_INTERNAL_TOKEN=changeme-internal-grpc-token
FENCEGUARD_GRPC_HOST=127.0.0.1
FENCEGUARD_GRPC_PORT=50051

# ── Upload limits ──────────────────────────────────────
FENCEGUARD_MAX_UPLOAD_MB=200

# ── CV Worker (Python) ─────────────────────────────────
FENCEGUARD_YOLO_CONFIDENCE=0.5
FENCEGUARD_YOLO_MODEL=yolov8n.pt
FENCEGUARD_POSE_COMPLEXITY=1
FENCEGUARD_PTZ_SMOOTHING_ALPHA=0.15
FENCEGUARD_PTZ_CROP_MARGIN=1.5
FENCEGUARD_PROCESSING_FPS_CAP=30

# ── Event Detection Thresholds ─────────────────────────
FENCEGUARD_LUNGE_VELOCITY_MULTIPLIER=2.5
FENCEGUARD_IMPACT_HEAD_SPEED_THRESHOLD=3.0
FENCEGUARD_FENCING_RESPONSE_DURATION_S=1.0
FENCEGUARD_FENCING_RESPONSE_ELBOW_EXTENDED_DEG=150
FENCEGUARD_FENCING_RESPONSE_ELBOW_FLEXED_DEG=90
FENCEGUARD_IMPACT_REFRACTORY_S=2.0
FENCEGUARD_LUNGE_REFRACTORY_S=1.5
FENCEGUARD_FR_REFRACTORY_S=5.0
